# =========================================
# YouTube → NotebookLM 플랫폼 환경 변수 설정
# .env.example을 복사하여 .env 파일 생성 후 값을 채워주세요
# =========================================

# --- YouTube Data API ---
# Google Cloud Console에서 발급: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# --- NotebookLM MCP 설정 ---
# nlm login 명령으로 인증 후 ~/.nlm/tokens.json에서 확인
# GitHub Actions에서는 이 값을 Secrets으로 관리
NLM_COOKIES=your_notebooklm_cookies_here

# --- 크롤러 설정 ---
# 최초 수집 시 가져올 최대 영상 수 (이후에는 신규 영상만 추가)
MAX_INITIAL_VIDEOS=20

# 신규 영상 확인 시 가져올 최근 영상 수 (보통 10개면 충분)
MAX_CHECK_VIDEOS=10

# 로그 레벨: debug | info | warn | error
LOG_LEVEL=info

# --- 알림 설정 (선택사항) ---
# 새 영상 추가 시 Slack 알림
SLACK_WEBHOOK_URL=

# 새 영상 추가 시 Telegram 알림
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
